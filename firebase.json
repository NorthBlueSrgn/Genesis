{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/api/companionGreeting", "function": "companionGreeting" },
      { "source": "/api/companionGreetingV2", "function": "companionGreetingV2" },
      { "source": "/api/orderChatV2", "function": "orderChatV2" },
      { "source": "/api/generateNewMission", "function": "generateNewMissionV2" },
      { "source": "/api/generateSideMission", "function": "generateSideMissionV2" },
      { "source": "/api/evaluateTaskReport", "function": "evaluateTaskReportV2" },
      { "source": "/api/generateChapter", "function": "generateChapterV2" },
      { "source": "/api/generateTacticalSuggestions", "function": "generateTacticalSuggestionsV2" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
